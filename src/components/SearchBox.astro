---
interface Props {
  placeholder?: string;
}

const { placeholder = "Search plugins by name, developer, or tags..." } =
  Astro.props;
---

<div class="relative">
  <svg
    class="absolute left-3 top-1/2 -translate-y-1/2 w-5 h-5 text-dark-400"
    fill="none"
    stroke="currentColor"
    viewBox="0 0 24 24"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      stroke-width="2"
      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
  </svg>
  <input
    type="text"
    id="plugin-search"
    placeholder={placeholder}
    class="w-full pl-10 pr-4 py-3 rounded-xl bg-dark-800 border border-dark-600 text-white placeholder-dark-400 focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
  />
</div>

<script>
  const searchInput = document.getElementById(
    "plugin-search",
  ) as HTMLInputElement;
  if (searchInput) {
    searchInput.addEventListener("input", () => {
      const query = searchInput.value.toLowerCase().trim();
      document.dispatchEvent(
        new CustomEvent("plugin-search", { detail: { query } }),
      );
    });
  }
</script>

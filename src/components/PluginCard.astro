---
import type { CollectionEntry } from "astro:content";

export interface Props {
  plugin: CollectionEntry<"plugins">;
}

const { plugin } = Astro.props;
const { data } = plugin;

const typeColors: Record<string, string> = {
  synth: "bg-accent/20 text-accent-light border-accent/30",
  effect: "bg-success/20 text-success border-success/30",
  sampler: "bg-warning/20 text-warning border-warning/30",
  utility: "bg-dark-500 text-dark-200 border-dark-400",
};
---

<a
  href={`/plugin/${plugin.data.name}`}
  class="group block bg-dark-800 rounded-xl border border-dark-600 overflow-hidden hover:border-accent/50 hover:shadow-lg hover:shadow-accent/5 transition-all duration-300"
>
  <div
    class="aspect-video bg-dark-700 flex items-center justify-center overflow-hidden"
  >
    {
      data.screenshot ? (
        <img
          src={data.screenshot}
          alt={`${data.name} screenshot`}
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          loading="lazy"
          onerror="this.onerror=null; this.src='/images/vsts/placeholder.png'; this.classList.add('object-contain', 'p-4')"
        />
      ) : (
        <img
          src="/images/vsts/placeholder.png"
          alt={`${data.name} placeholder`}
          class="w-full h-full object-contain p-4"
        />
      )
    }
  </div>
  <div class="p-4 space-y-3">
    <div class="flex items-start justify-between gap-2">
      <div class="min-w-0">
        <h3
          class="font-semibold text-white truncate group-hover:text-accent-light transition-colors"
        >
          {data.name}
        </h3>
        <p class="text-sm text-dark-300 truncate">{data.developer}</p>
      </div>
      <span
        class={`shrink-0 px-2 py-0.5 rounded text-xs font-medium border capitalize ${typeColors[data.type] || typeColors.utility}`}
      >
        {data.type}
      </span>
    </div>

    <div class="flex flex-wrap gap-1.5">
      {
        data.genreTags
          .slice(0, 3)
          .map((tag) => (
            <span class="px-2 py-0.5 rounded text-xs bg-dark-600 text-dark-200">
              {tag}
            </span>
          ))
      }
      {
        data.genreTags.length > 3 && (
          <span class="px-2 py-0.5 rounded text-xs bg-dark-600 text-dark-300">
            +{data.genreTags.length - 3}
          </span>
        )
      }
    </div>

    <div class="flex items-center justify-between pt-1">
      <div class="flex gap-1.5">
        {
          data.osSupport.map((os) => (
            <span
              class="w-5 h-5 flex items-center justify-center rounded text-xs bg-dark-700 text-dark-300 capitalize"
              title={os}
            >
              {os === "windows" ? "W" : os === "macos" ? "M" : "L"}
            </span>
          ))
        }
      </div>
      <span class="text-sm font-medium text-accent-light">
        {data.price === "Free" ? "Free" : data.price}
      </span>
    </div>
  </div>
</a>

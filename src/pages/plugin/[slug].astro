---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import PluginCard from "../../components/PluginCard.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const plugins = await getCollection("plugins", ({ data }) => data.isActive);
  return plugins.map((plugin) => ({
    params: { slug: plugin.id.replace(/\.md$/, "") },
    props: { plugin },
  }));
}

const { plugin } = Astro.props;
const pluginSlug = plugin.id.replace(/\.md$/, "");
const { data } = plugin;

const allPlugins = await getCollection("plugins", ({ data }) => data.isActive);
const related = allPlugins
  .filter(
    (p) =>
      p.id.replace(/\.md$/, "") !== pluginSlug && p.data.type === data.type,
  )
  .slice(0, 3);

const typeColors: Record<string, string> = {
  synth: "text-accent-light",
  effect: "text-success",
  sampler: "text-warning",
  utility: "text-dark-200",
};
---

<BaseLayout title={data.name}>
  <Header slot="header" />

  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Back link -->
    <a
      href="/plugins"
      class="inline-flex items-center gap-1 text-sm text-dark-400 hover:text-accent-light transition-colors mb-8 group"
    >
      <svg
        class="w-4 h-4 transition-transform group-hover:-translate-x-1"
        fill="none"
        stroke="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 19l-7-7 7-7"></path>
      </svg>
      Back to Plugins
    </a>

    <!-- Hero Image -->
    <!-- Hero Image -->
    <div class="mb-8 -mx-4 sm:-mx-6 lg:-mx-8">
      <div class="relative w-full aspect-video bg-dark-800 rounded-lg">
        {
          data.screenshot ? (
            <img
              src={data.screenshot}
              alt={`${data.name} screenshot`}
              class="absolute inset-0 w-full h-full object-cover rounded-lg"
              onerror="this.src='/images/vsts/placeholder.png'; this.classList.add('object-contain', 'p-4')"
            />
          ) : (
            <img
              src="/images/vsts/placeholder.png"
              alt={`${data.name} placeholder`}
              class="w-full h-full object-contain p-4"
            />
          )
        }
      </div>
    </div>

    <!-- Header Section -->
    <header class="mb-8">
      <div class="flex items-center gap-3 mb-4">
        <span
          class={`text-sm font-medium capitalize ${typeColors[data.type] || typeColors.utility}`}
        >
          {data.type}
        </span>
        <span class="text-dark-600">·</span>
        <span class="text-sm text-dark-400">by {data.developer}</span>
      </div>

      <h1 class="text-4xl sm:text-5xl font-bold text-white leading-tight mb-4">
        {data.name}
      </h1>

      <!-- Genre Tags -->
      {
        data.genreTags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {data.genreTags.map((tag) => (
              <a
                href={`/genre/${tag.toLowerCase().replace(/\s+/g, "-")}`}
                class="text-sm text-dark-400 hover:text-accent-light transition-colors"
              >
                #{tag.toLowerCase().replace(/\s+/g, "-")}
              </a>
            ))}
          </div>
        )
      }
    </header>

    <!-- Main Content -->
    <div
      class="prose prose-invert max-w-none prose-headings:text-white prose-a:text-accent-light hover:prose-a:text-accent mb-12"
    >
      {plugin.body}
    </div>

    <!-- Metadata Section -->
    <div class="border-t border-dark-700 pt-8 mb-12">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-sm">
        <div>
          <dt class="text-dark-500 mb-1">Price</dt>
          <dd class="text-white font-semibold text-lg">{data.price}</dd>
        </div>

        <div class="col-span-2 sm:col-span-1">
          <dt class="text-dark-500 mb-2">Supported OS</dt>
          <dd class="flex flex-wrap gap-2">
            {
              data.osSupport.map((os) => (
                <a
                  href={`/os/${os}`}
                  class="text-dark-300 hover:text-accent-light transition-colors capitalize"
                >
                  {os === "macos" ? "macOS" : os}
                </a>
              ))
            }
          </dd>
        </div>

        <div class="col-span-2 sm:col-span-1">
          <dt class="text-dark-500 mb-2">Formats</dt>
          <dd class="flex flex-wrap gap-2">
            {data.format.map((fmt) => <span class="text-dark-300">{fmt}</span>)}
          </dd>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mb-16">
      <a
        href={data.downloadUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-lg bg-accent text-white font-medium hover:bg-accent-dark transition-colors"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
          ></path>
        </svg>
        Download from Official Site
      </a>
    </div>

    <!-- Related Plugins -->
    {
      related.length > 0 && (
        <section class="border-t border-dark-700 pt-12">
          <h2 class="text-xl font-semibold text-white mb-6">
            More {data.type} plugins
          </h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {related.map((p) => (
              <PluginCard plugin={p} />
            ))}
          </div>
        </section>
      )
    }
  </article>
</BaseLayout>
